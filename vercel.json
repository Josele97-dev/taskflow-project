{
  "version": 2,
  "builds": [
    { "src": "server/src/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "output.css", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/src/index.js" },
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/output.css", "dest": "/output.css" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}